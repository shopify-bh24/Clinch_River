{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  .section-{{ section.id }}-margin {
    margin-top: {{ section.settings.margin_top_mobile }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .section-{{ section.id }}-margin {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }
{% endstyle %}

{% assign section_background = '' %}

{% if section.settings.section_background != blank %}
  {% assign section_background = 'background: ' | append: section.settings.section_background | append: ';' %}
{% endif %}

{% assign desktop_content_alignment = section.settings.desktop_content_alignment %}
{% assign mobile_content_alignment = section.settings.mobile_content_alignment %}

<div
  class="pagepilot-section pagepilot-image-with-benefits section-{{ section.id }}-padding section-{{ section.id }}-margin"
  style="{{ section_background }}"
>
  <div class="pagepilot-wrapper">
    <div class="pp-container pp-mx-auto pp-w-full">
      <div class="pp-flex pp-flex-col pp-gap-6">
        <h2 class="pp-text-heading-lg md:pp-text-heading-2xl pp-font-semibold pp-text-{{ mobile_content_alignment }} md:pp-text-{{ desktop_content_alignment }}"">
          {{ section.settings.heading }}
        </h2>
        {% if section.settings.subtitle != blank %}
        <div class="pp-w-full {% if desktop_content_alignment == 'center' %}pp-max-w-5xl pp-mx-auto{% endif %}">
          <p class="pp-text-lg md:pp-text-xl pp-leading-7 pp-text-{{ mobile_content_alignment }} md:pp-text-{{ desktop_content_alignment }}"">{{ section.settings.subtitle }}</p>
        </div>
        {% endif %}
      </div>

      <div class="pp-w-full pp-items-center pp-justify-center pp-flex pp-flex-col sm:pp-grid pp-grid-cols-1 md:pp-grid-cols-4 pp-gap-y-10 md:pp-gap-10 pp-mt-10">
        <div class="pp-w-full pp-flex pp-flex-col pp-justify-center pp-items-center sm:pp-grid sm:pp-grid-cols-2 sm:pp-justify-normal sm:pp-items-start md:pp-flex md:pp-flex-col pp-mx-auto md:pp-items-center md:pp-justify-center pp-gap-12 sm:pp-order-1 pp-order-3">
          {% for block in section.blocks %}
            {% if block.type == 'benefit' and forloop.index <= 2 %}
              <div class="pp-flex pp-flex-col pp-items-center pp-justify-center pp-text-center pp-gap-2">
                <div class="pp-text-3xl">{{ block.settings.icon }}</div>
                <div class="pp-text-xl pp-font-semibold pp-tracking-normal">{{ block.settings.title }}</div>
                <div class="pp-text-base">{{ block.settings.description }}</div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
        <div class="pp-w-full pp-col-span-2 pp-flex pp-items-start md:pp-items-end pp-justify-center pp-order-2">
          <div class="pp-aspect-square pp-w-full pp-max-w-[500px] pp-max-h-[750px] pp-relative pp-overflow-hidden {% if section.settings.image_rounded_type == 'circle' %}pp-rounded-full{% endif %} pp-flex pp-items-center pp-justify-center"
            {% if section.settings.image_rounded_type == 'default' %}
              style="border-radius: var(--pp-border-radius);"
            {% endif %}
          >
            {% if section.settings.image %}
              <img
                src="{{ section.settings.image | image_url: width: 600 }}"
                alt="{{ section.settings.image.alt | escape }}"
                class="pp-w-auto pp-h-auto pp-object-contain pp-object-center pp-max-w-full pp-max-h-full pp-absolute pp-top-1/2 pp-left-1/2 -pp-translate-x-1/2 -pp-translate-y-1/2"
                width="100%"
                height="100%"
                {% if section.settings.image_rounded_type == 'default' %}
                  style="border-radius: var(--pp-border-radius);"
                {% endif %}
              >
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'pp-w-full' }}
            {% endif %}
          </div>
        </div>
        <div class="pp-flex pp-flex-col pp-justiffy-center pp-items-center sm:pp-flex-row md:pp-flex-col pp-mx-auto pp-justify-center pp-gap-8 md:pp-gap-10 pp-order-3">
          {% for block in section.blocks %}
            {% if block.type == 'benefit' and forloop.index > 2 %}
              <div class="pp-flex pp-flex-col pp-items-center pp-justify-center pp-text-center pp-gap-2">
                <div class="pp-text-3xl">{{ block.settings.icon }}</div>
                <div class="pp-text-xl pp-font-semibold pp-tracking-normal">{{ block.settings.title }}</div>
                <div class="pp-text-base">{{ block.settings.description }}</div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
	"name": "PP Image with Benefits",
	"class": "section",
	"settings": [
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Your Headline Here"
		},
		{
			"type": "textarea",
			"id": "subtitle",
			"label": "Subtitle",
			"default": "Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s."
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "Image"
		},
		{
			"type": "select",
			"id": "image_rounded_type",
			"options": [
				{
					"value": "circle",
					"label": "Circle"
				},
				{
					"value": "default",
					"label": "Default"
				},
			],
			"default": "circle",
			"label": "Image rounded type"
		},
		{
			"type": "select",
			"id": "desktop_content_alignment",
			"options": [
				{
					"value": "left",
					"label": "Left"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "right",
					"label": "Right"
				}
			],
			"default": "center",
			"label": "Desktop content alignment"
		},
		{
			"type": "select",
			"id": "mobile_content_alignment",
			"options": [
				{
					"value": "left",
					"label": "Left"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "right",
					"label": "Right"
				}
			],
			"default": "center",
			"label": "Mobile content alignment"
		},
		{
			"type": "color_background",
			"id": "section_background",
			"label": "Background color"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Top padding",
			"default": 30
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Bottom padding",
			"default": 30
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Top padding (mobile)",
			"default": 30
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Bottom padding (mobile)",
			"default": 30
		},
		{
			"type": "range",
			"id": "margin_top",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Top margin",
			"default": 30
		},
		{
			"type": "range",
			"id": "margin_bottom",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Bottom margin",
			"default": 30
		},
		{
			"type": "range",
			"id": "margin_top_mobile",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Top margin (mobile)",
			"default": 30
		},
		{
			"type": "range",
			"id": "margin_bottom_mobile",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Bottom margin (mobile)",
			"default": 30
		}
	],
	"blocks": [
		{
			"type": "benefit",
			"name": "Benefit",
			"limit": 4,
			"settings": [
				{
					"type": "text",
					"id": "icon",
					"label": "Icon (emoji)",
					"default": "🔥"
				},
				{
					"type": "text",
					"id": "title",
					"label": "Title",
					"default": "Benefit"
				},
				{
					"type": "textarea",
					"id": "description",
					"label": "Description",
					"default": "Add a short text that describes the benefit of the product."
				}
			]
		}
	],
	"presets": [
		{
			"name": "PP Image with Benefits",
			"blocks": [
				{
					"type": "benefit"
				},
				{
					"type": "benefit"
				},
				{
					"type": "benefit"
				},
				{
					"type": "benefit"
				}
			]
		}
	]
}
{% endschema %}
