{% style %}
	.section-{{ section.id }}-padding {
	  padding-top: {{ section.settings.padding_top_mobile }}px;
	  padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
	}
	.section-{{ section.id }}-margin {
	  margin-top: {{ section.settings.margin_top_mobile }}px;
	  margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
	}

	@media screen and (min-width: 750px) {
	  .section-{{ section.id }}-padding {
	    padding-top: {{ section.settings.padding_top }}px;
	    padding-bottom: {{ section.settings.padding_bottom }}px;
	  }
	  .section-{{ section.id }}-margin {
	    margin-top: {{ section.settings.margin_top }}px;
	    margin-bottom: {{ section.settings.margin_bottom }}px;
	  }
	}
{% endstyle %}

{% assign section_background = '' %}

{% if section.settings.section_background != blank %}
	{% assign section_background = 'background: ' | append: section.settings.section_background | append: ';' %}
{% endif %}

<div
	class='pagepilot-section pagepilot-review-slider section-{{ section.id }}-padding section-{{ section.id }}-margin'
	style='{{ section_background }}'
	id='reviews-slider'>
	<div
		class='pagepilot-wrapper'>
		<div class='pp-container pp-mx-auto pp-w-full pp-justify-center'>
			<div
				class='pp-flex pp-flex-col pp-gap-14 pp-p-4 pp-m-auto pp-items-{{ section.settings.mobile_content_alignment | replace: 'left', 'start' | replace: 'right', 'end' }} md:pp-items-{{ section.settings.desktop_content_alignment | replace: 'left', 'start' | replace: 'right', 'end' }}'>
				<div class='pp-flex pp-flex-col pp-gap-8'>
					<div class='pp-flex pp-gap-1 pp-justify-{{ section.settings.mobile_content_alignment | replace: 'left', 'start' | replace: 'right', 'end' }} md:pp-justify-{{ section.settings.desktop_content_alignment | replace: 'left', 'start' | replace: 'right', 'end' }}''>
						{% for i in (1..section.settings.rating) %}
							<svg xmlns='http://www.w3.org/2000/svg' class='pp-w-6 pp-h-6 pp-fill-yellow-400' viewBox='0 0 256 256'>
								<path d="M234.29,114.85l-45,38.83L203,211.75a16.4,16.4,0,0,1-24.5,17.82L128,198.49,77.47,229.57A16.4,16.4,0,0,1,53,211.75l13.76-58.07-45-38.83A16.46,16.46,0,0,1,31.08,86l59-4.76,22.76-55.08a16.36,16.36,0,0,1,30.27,0l22.75,55.08,59,4.76a16.46,16.46,0,0,1,9.37,28.86Z"></path>
							</svg>
						{% endfor %}
					</div>
					<h2 class='pp-text-heading-lg sm:pp-text-heading-2xl pp-font-semibold pp-text-{{ section.settings.mobile_content_alignment }} md:pp-text-{{ section.settings.desktop_content_alignment }}'>
						{{ section.settings.heading }}
					</h2>
					{% if section.settings.subheading != blank %}
						<div class='pp-text-lg md:pp-text-xl pp-font-medium {% if section.settings.desktop_content_alignment == 'center' %}md:pp-max-w-8xl{% endif %} pp-text-{{ section.settings.mobile_content_alignment }} md:pp-text-{{ section.settings.desktop_content_alignment }}'>
							{{ section.settings.subheading }}
						</div>
					{% endif %}
				</div>

				<div class='pp-w-full'>
					<div class='pp-px-[50px] pp-relative'>
						<div class='swiper pp-reviews-swiper pp-pb-10 pp-px-2 md:pp-px-3.5 pp-overflow-hidden pp-mx-auto pp-z-2 pp-block pp-touch-pan-y pp-list-none pp-relative'>
							<div class='swiper-wrapper pp-relative pp-w-full pp-h-full pp-flex pp-box-content pp-transition-transform hover:pp-cursor-pointer'>
								{% for block in section.blocks %}
									{% if block.type == 'review' %}
										<div class='swiper-slide pp-shrink-0 pp-h-full pp-relative pp-transition-transform pp-block'>
											<div
												class='pp-w-full pp-h-fit pp-flex pp-flex-col pp-text-left pp-border-solid pp-border pp-border-gray-200 pp-shadow-black/7 pp-shadow pp-break-inside-avoid-column pp-bg-white'
												style='border-radius: var(--pp-border-radius);'>
												<div class='pp-p-4'>
													{% if block.settings.image != blank %}
														{{
															block.settings.image
															| image_url: width: 300
															| image_tag:
																class: 'pp-w-auto pp-mx-auto pp-max-w-full pp-max-h-[200px]',
																loading: 'lazy',
																style: 'border-radius: var(--pp-border-radius);'
														}}
													{% endif %}

													<div class='pp-text-sm sm:pp-text-base pp-mt-4 pp-text-left pp-font-semibold'>
														{{ block.settings.name }}
													</div>

													{% if block.settings.verified_text != blank %}
														<div class='pp-flex pp-gap-2 pp-items-center pp-justify-start pp-font-medium pp-mt-2 pp-text-sm pp-text-left'>
															<svg
																xmlns='http://www.w3.org/2000/svg'
																class='pp-w-4 pp-h-4 pp-fill-[#2c95e9]'
																viewBox='0 0 256 256'>
																<path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm45.66,85.66-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35a8,8,0,0,1,11.32,11.32Z"></path>
															</svg>
															{{ block.settings.verified_text }}
														</div>
													{% endif %}
													<div class='pp-mt-4 pp-flex'>
														{% for i in (1..block.settings.rating) %}
															<svg
																xmlns='http://www.w3.org/2000/svg'
																class='pp-size-3 sm:pp-size-5 pp-fill-yellow-400'
																viewBox='0 0 256 256'>
																<path d="M234.29,114.85l-45,38.83L203,211.75a16.4,16.4,0,0,1-24.5,17.82L128,198.49,77.47,229.57A16.4,16.4,0,0,1,53,211.75l13.76-58.07-45-38.83A16.46,16.46,0,0,1,31.08,86l59-4.76,22.76-55.08a16.36,16.36,0,0,1,30.27,0l22.75,55.08,59,4.76a16.46,16.46,0,0,1,9.37,28.86Z"></path>
															</svg>
														{% endfor %}
													</div>

													<div class='pp-text-sm sm:pp-text-base pp-mt-4 pp-text-left'>
														{{ block.settings.review_text }}
													</div>
												</div>
											</div>
										</div>
									{% endif %}
								{% endfor %}
							</div>
							<div
								class='swiper-pagination pp-bottom-0 pp-w-full pp-absolute pp-text-center pp-z-10 pp-transition-all pp-duration-300 pp-ease-in [&>*]:pp-w-2 [&>*]:pp-h-2 [&>*]:pp-bg-gray-400 [&>*]:pp-mx-1 [&>*]:pp-inline-block [&>*]:pp-rounded-full [&>.swiper-pagination-bullet-active]:pp-bg-black'></div>
						</div>

						<div class='swiper-button-prev pp-rounded-full pp-absolute pp-top-1/2 pp--translate-y-1/2 pp-left-0 pp-w-8 pp-h-8 md:pp-w-10 md:pp-h-10 lg:pp-w-10 lg:pp-h-10 pp-flex pp-justify-center pp-items-center hover:pp-cursor-pointer !pp-bg-white after:pp-content-none'>
							<svg xmlns='http://www.w3.org/2000/svg' class='pp-w-full pp-h-full pp-max-w-[30px]' viewBox='0 0 256 256'>
								<path d="M168.49,199.51a12,12,0,0,1-17,17l-80-80a12,12,0,0,1,0-17l80-80a12,12,0,0,1,17,17L97,128Z"></path>
							</svg>
						</div>

						<div class='swiper-button-next pp-rounded-full pp-absolute pp-top-1/2 pp--translate-y-1/2 pp-right-0 pp-w-8 pp-h-8 md:pp-w-10 md:pp-h-10 lg:pp-w-10 lg:pp-h-10 pp-flex pp-justify-center pp-items-center hover:pp-cursor-pointer !pp-bg-white after:pp-content-none'>
							<svg xmlns='http://www.w3.org/2000/svg' class='pp-w-full pp-h-full pp-max-w-[30px]' viewBox='0 0 256 256'>
								<path d="M184.49,136.49l-80,80a12,12,0,0,1-17-17L159,128,87.51,56.49a12,12,0,1,1,17-17l80,80A12,12,0,0,1,184.49,136.49Z"></path>
							</svg>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<script src='https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js'></script>
<script>
	const initSwiper = () => {
		new Swiper('.pp-reviews-swiper', {
			direction: 'horizontal',
			loop: true,
			pagination: {
				el: '.swiper-pagination',
			},
			navigation: {
				nextEl: '.swiper-button-next',
				prevEl: '.swiper-button-prev',
			},
			slidesPerView: 1,
			spaceBetween: 10,
			autoplay: {
				delay: 3000,
				disableOnInteraction: true,
				pauseOnMouseEnter: true,
			},
			breakpoints: {
				480: {
					slidesPerView: 1,
					spaceBetween: 20,
				},
				640: {
					slidesPerView: 2,
					spaceBetween: 20,
				},
				1024: {
					slidesPerView: 3,
					spaceBetween: 30,
				},
			},
		});
	};

	// Try to initialize immediately
	if (window.Swiper) {
		initSwiper();
	} else {
		// If Swiper isn't loaded yet, wait for it
		document.addEventListener('DOMContentLoaded', function () {
			if (window.Swiper) {
				initSwiper();
			} else {
				// If still not loaded after DOMContentLoaded, wait for script load
				document.querySelector('script[src*="swiper"]').addEventListener('load', initSwiper);
			}
		});
	}
</script>

{% schema %}
{
	"name": "PP Review Carousel",
	"settings": [
		{
			"type": "range",
			"id": "rating",
			"min": 1,
			"max": 5,
			"step": 1,
			"label": "Rating",
			"default": 5
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "What people are saying"
		},
		{
			"type": "text",
			"id": "subheading",
			"label": "Subheading",
			"default": "Rated 4.8/5 by 5,000+ Happy Customers"
		},
		{
			"type": "select",
			"id": "desktop_content_alignment",
			"options": [
				{
					"value": "left",
					"label": "Left"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "right",
					"label": "Right"
				}
			],
			"default": "center",
			"label": "Desktop content alignment"
		},
		{
			"type": "select",
			"id": "mobile_content_alignment",
			"options": [
				{
					"value": "left",
					"label": "Left"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "right",
					"label": "Right"
				}
			],
			"default": "center",
			"label": "Mobile content alignment"
		},
		{
			"type": "color_background",
			"id": "section_background",
			"label": "Background color"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Top padding",
			"default": 30
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Bottom padding",
			"default": 30
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Top padding (mobile)",
			"default": 30
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Bottom padding (mobile)",
			"default": 30
		},
		{
			"type": "range",
			"id": "margin_top",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Top margin",
			"default": 30
		},
		{
			"type": "range",
			"id": "margin_bottom",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Bottom margin",
			"default": 30
		},
		{
			"type": "range",
			"id": "margin_top_mobile",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Top margin (mobile)",
			"default": 30
		},
		{
			"type": "range",
			"id": "margin_bottom_mobile",
			"min": 0,
			"max": 200,
			"step": 2,
			"unit": "px",
			"label": "Bottom margin (mobile)",
			"default": 30
		}
	],
	"blocks": [
		{
			"type": "review",
			"name": "Review",
			"settings": [
				{
					"type": "image_picker",
					"id": "image",
					"label": "Reviewer Image"
				},
				{
					"type": "text",
					"id": "name",
					"label": "Reviewer Name",
					"default": "John D."
				},
				{
					"type": "text",
					"id": "verified_text",
					"label": "Verified Text",
					"default": "Verified Buyer"
				},
				{
					"type": "range",
					"id": "rating",
					"min": 1,
					"max": 5,
					"step": 1,
					"label": "Rating",
					"default": 5
				},
				{
					"type": "textarea",
					"id": "review_text",
					"label": "Review Text",
					"default": "In this field, you can put the most amazing review you have received from your customer. Use it as the best selling reference for your product."
				}
			]
		}
	],
	"presets": [
		{
			"name": "PP Review Carousel",
			"blocks": [
				{
					"type": "review"
				},
				{
					"type": "review"
				},
				{
					"type": "review"
				}
			]
		}
	]
}
{% endschema %}
