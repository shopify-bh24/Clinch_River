{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-editorial-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-editorial-feature-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-editorial-feature-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.feature_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-feature-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.feature_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-editorial-feature-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-feature-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.content_padding }}px;
    background: linear-gradient(to top, rgba(0,0,0,{{ block.settings.overlay_opacity }}), transparent);
    color: {{ block.settings.feature_text_color }};
  }

  .ai-editorial-feature-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_size }}px;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
    font-weight: 600;
    color: {{ block.settings.category_color }};
  }

  .ai-editorial-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size }}px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 12px 0;
    color: {{ block.settings.feature_text_color }};
  }

  .ai-editorial-feature-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    line-height: 1.6;
    margin: 0 0 16px 0;
    color: {{ block.settings.feature_text_color }};
    opacity: 0.9;
  }

  .ai-editorial-feature-meta-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.feature_text_color }};
    opacity: 0.8;
  }

  .ai-editorial-article-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.card_background }};
    transition: transform 0.3s ease;
  }

  .ai-editorial-article-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-editorial-article-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.article_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-article-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.article_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-article-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-article-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-editorial-article-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_size }}px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 8px;
    font-weight: 600;
    color: {{ block.settings.category_color }};
  }

  .ai-editorial-article-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.article_title_size }}px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 8px 0;
    color: {{ block.settings.text_color }};
  }

  .ai-editorial-article-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.article_excerpt_size }}px;
    line-height: 1.6;
    margin: 0 0 12px 0;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
  }

  .ai-editorial-article-meta-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  .ai-editorial-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .ai-editorial-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 768px) {
    .ai-editorial-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-editorial-feature-height-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_feature_height }}px;
    }

    .ai-editorial-feature-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.feature_title_size | times: 0.7 }}px;
    }

    .ai-editorial-article-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.article_title_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-editorial-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-container-{{ ai_gen_id }}">
    <div class="ai-editorial-feature-{{ ai_gen_id }}">
      {% if block.settings.feature_article %}
        <a href="{{ block.settings.feature_article.url }}" class="ai-editorial-link-{{ ai_gen_id }}">
          {% if block.settings.feature_article.image %}
            <img
              src="{{ block.settings.feature_article.image | image_url: width: 1400 }}"
              alt="{{ block.settings.feature_article.image.alt | escape }}"
              class="ai-editorial-feature-image-{{ ai_gen_id }}"
              loading="lazy"
              width="1400"
              height="{{ block.settings.feature_height }}"
            >
          {% else %}
            <div class="ai-editorial-feature-placeholder-{{ ai_gen_id }}">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
          <div class="ai-editorial-feature-content-{{ ai_gen_id }}">
            {% if block.settings.show_category and block.settings.feature_article.tags.size > 0 %}
              <div class="ai-editorial-feature-category-{{ ai_gen_id }}">
                {{ block.settings.feature_article.tags.first }}
              </div>
            {% endif %}
            <h2 class="ai-editorial-feature-title-{{ ai_gen_id }}">
              {{ block.settings.feature_article.title }}
            </h2>
            {% if block.settings.show_excerpt and block.settings.feature_article.excerpt != blank %}
              <div class="ai-editorial-feature-excerpt-{{ ai_gen_id }}">
                {{ block.settings.feature_article.excerpt | strip_html | truncate: 150 }}
              </div>
            {% endif %}
            {% if block.settings.show_date %}
              <div class="ai-editorial-feature-meta-{{ ai_gen_id }}">
                {{ block.settings.feature_article.published_at | date: '%B %d, %Y' }}
              </div>
            {% endif %}
          </div>
        </a>
      {% else %}
        <div class="ai-editorial-feature-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-editorial-empty-state-{{ ai_gen_id }}">
            Select a featured article
          </div>
        </div>
      {% endif %}
    </div>

    {% for i in (1..4) %}
      {% liquid
        assign article_key = 'article_' | append: i
        assign article = block.settings[article_key]
      %}
      <div class="ai-editorial-article-{{ ai_gen_id }}">
        {% if article %}
          <a href="{{ article.url }}" class="ai-editorial-link-{{ ai_gen_id }}">
            {% if article.image %}
              <img
                src="{{ article.image | image_url: width: 700 }}"
                alt="{{ article.image.alt | escape }}"
                class="ai-editorial-article-image-{{ ai_gen_id }}"
                loading="lazy"
                width="700"
                height="{{ block.settings.article_height }}"
              >
            {% else %}
              <div class="ai-editorial-article-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
            <div class="ai-editorial-article-content-{{ ai_gen_id }}">
              {% if block.settings.show_category and article.tags.size > 0 %}
                <div class="ai-editorial-article-category-{{ ai_gen_id }}">
                  {{ article.tags.first }}
                </div>
              {% endif %}
              <h3 class="ai-editorial-article-title-{{ ai_gen_id }}">
                {{ article.title }}
              </h3>
              {% if block.settings.show_excerpt and article.excerpt != blank %}
                <div class="ai-editorial-article-excerpt-{{ ai_gen_id }}">
                  {{ article.excerpt | strip_html | truncate: 100 }}
                </div>
              {% endif %}
              {% if block.settings.show_date %}
                <div class="ai-editorial-article-meta-{{ ai_gen_id }}">
                  {{ article.published_at | date: '%B %d, %Y' }}
                </div>
              {% endif %}
            </div>
          </a>
        {% else %}
          <div class="ai-editorial-article-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
          <div class="ai-editorial-article-content-{{ ai_gen_id }}">
            <div class="ai-editorial-article-category-{{ ai_gen_id }}">Category</div>
            <h3 class="ai-editorial-article-title-{{ ai_gen_id }}">Article title</h3>
            <div class="ai-editorial-article-excerpt-{{ ai_gen_id }}">
              Select an article to display here
            </div>
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Magazine editorial",
  "settings": [
    {
      "type": "header",
      "content": "Featured article"
    },
    {
      "type": "article",
      "id": "feature_article",
      "label": "Featured article"
    },
    {
      "type": "range",
      "id": "feature_height",
      "label": "Featured image height",
      "min": 300,
      "max": 700,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "mobile_feature_height",
      "label": "Mobile featured height",
      "min": 200,
      "max": 500,
      "step": 50,
      "unit": "px",
      "default": 350
    },
    {
      "type": "header",
      "content": "Articles"
    },
    {
      "type": "article",
      "id": "article_1",
      "label": "Article 1"
    },
    {
      "type": "article",
      "id": "article_2",
      "label": "Article 2"
    },
    {
      "type": "article",
      "id": "article_3",
      "label": "Article 3"
    },
    {
      "type": "article",
      "id": "article_4",
      "label": "Article 4"
    },
    {
      "type": "range",
      "id": "article_height",
      "label": "Article image height",
      "min": 150,
      "max": 400,
      "step": 25,
      "unit": "px",
      "default": 250
    },
    {
      "type": "header",
      "content": "Display options"
    },
    {
      "type": "checkbox",
      "id": "show_category",
      "label": "Show category",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "label": "Mobile gap",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content padding",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "feature_text_color",
      "label": "Featured text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "category_color",
      "label": "Category",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.7
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "feature_title_size",
      "label": "Featured title size",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "range",
      "id": "article_title_size",
      "label": "Article title size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "category_size",
      "label": "Category size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "excerpt_size",
      "label": "Featured excerpt size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "article_excerpt_size",
      "label": "Article excerpt size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "meta_size",
      "label": "Meta text size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 13
    }
  ],
  "presets": [
    {
      "name": "Magazine editorial"
    }
  ]
}
{% endschema %}