{% doc %}
  @prompt
    Create a Shop Pay Installments messaging block for product pages that displays "As low as [amount]/mo with Shop Pay" near the price or Add to Cart button. The block should use Shopify's built-in Shop Pay Installments liquid objects or the shop-pay-installments component to dynamically calculate and display the installment amount based on the product price. Style it to match a premium, dark aesthetic with the Shop Pay logo/branding. It should only display when the product price is within the eligible range for Shop Pay Installments.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-shop-pay-installments-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: {{ block.settings.spacing_top }}px 0 {{ block.settings.spacing_bottom }}px 0;
  }

  .ai-shop-pay-installments-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-shop-pay-installments-logo-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.logo_width }}px;
    height: auto;
  }

  .ai-shop-pay-installments-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.4;
    margin: 0;
  }

  .ai-shop-pay-installments-amount-{{ ai_gen_id }} {
    font-weight: {{ block.settings.amount_font_weight }};
    color: {{ block.settings.amount_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-shop-pay-installments-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-shop-pay-installments-wrapper-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px {{ block.settings.padding_horizontal | times: 0.8 }}px;
    }

    .ai-shop-pay-installments-logo-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width | times: 0.8 }}px;
    }

    .ai-shop-pay-installments-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

{% liquid
  assign min_price = block.settings.min_eligible_price | times: 100
  assign max_price = block.settings.max_eligible_price | times: 100
  assign product_price = product.price
  assign is_eligible = false

  if product_price >= min_price and product_price <= max_price
    assign is_eligible = true
  endif

  assign installment_amount = product_price | divided_by: 4
%}

{% if is_eligible %}
  <shop-pay-installments-{{ ai_gen_id }}
    class="ai-shop-pay-installments-{{ ai_gen_id }}"
    {{ block.shopify_attributes }}
  >
    <div class="ai-shop-pay-installments-wrapper-{{ ai_gen_id }}">
      {% if block.settings.show_logo %}
        <svg
          class="ai-shop-pay-installments-logo-{{ ai_gen_id }}"
          viewBox="0 0 80 20"
          xmlns="http://www.w3.org/2000/svg"
          role="img"
          aria-label="Shop Pay"
        >
          <path
            fill="{{ block.settings.logo_color }}"
            d="M12.5 0C8.4 0 5.5 2.4 5.5 6.2c0 2.5 1.3 4.2 3.8 5.5 1.8 1 2.4 1.6 2.4 2.6 0 1.2-1 2-2.6 2-2.1 0-3.8-1-5.1-2.1L2.5 17c1.7 1.5 4 2.3 6.5 2.3 4.5 0 7.5-2.2 7.5-6.2 0-2.6-1.4-4.3-4-5.6-1.7-.9-2.3-1.5-2.3-2.5 0-1.1.9-1.9 2.3-1.9 1.8 0 3.3.8 4.4 1.7L18.5 2c-1.5-1.3-3.5-2-6-2zm17.8.3L27 18.9h5.3l.6-2.2h6.8l.6 2.2h5.8L42.8.3h-12.5zm17.9 0v18.6h5.2V8.7l5.6 10.2h3.5l5.6-10.2v10.2h5.2V.3h-6.8l-5.7 10.5L54.1.3h-5.9zM6.5 1.3c.9 0 1.6.7 1.6 1.6 0 .9-.7 1.6-1.6 1.6-.9 0-1.6-.7-1.6-1.6 0-.9.7-1.6 1.6-1.6zm29.8 4.4h1.9l2.3 8.5-4.2-8.5z"
          />
        </svg>
      {% endif %}

      <p class="ai-shop-pay-installments-text-{{ ai_gen_id }}">
        {% if block.settings.custom_text != blank %}
          {{ block.settings.custom_text | replace: '[amount]', '<span class="ai-shop-pay-installments-amount-' | append: ai_gen_id | append: '">' | append: installment_amount | money | append: '</span>' }}
        {% else %}
          As low as
          <span class="ai-shop-pay-installments-amount-{{ ai_gen_id }}">{{ installment_amount | money }}</span
          >/mo with Shop Pay
        {% endif %}
      </p>
    </div>
  </shop-pay-installments-{{ ai_gen_id }}>
{% endif %}

<script>
  (function () {
    class ShopPayInstallments{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupPriceObserver();
      }

      setupPriceObserver() {
        const productForm = document.querySelector('form[action*="/cart/add"]');
        if (!productForm) return;

        const variantSelect = productForm.querySelector('[name="id"]');
        if (!variantSelect) return;

        variantSelect.addEventListener('change', () => {
          this.updateInstallmentAmount();
        });
      }

      updateInstallmentAmount() {
        const productForm = document.querySelector('form[action*="/cart/add"]');
        if (!productForm) return;

        const variantSelect = productForm.querySelector('[name="id"]');
        if (!variantSelect) return;

        const selectedVariantId = variantSelect.value;
        const priceElement = document.querySelector('[data-product-price]');

        if (priceElement) {
          const priceText = priceElement.textContent.trim();
          const priceMatch = priceText.match(/[\d,]+\.?\d*/);

          if (priceMatch) {
            const price = parseFloat(priceMatch[0].replace(/,/g, ''));
            const minPrice = {{ block.settings.min_eligible_price }};
            const maxPrice = {{ block.settings.max_eligible_price }};

            if (price >= minPrice && price <= maxPrice) {
              const installmentAmount = price / 4;
              const amountElement = this.querySelector('.ai-shop-pay-installments-amount-{{ ai_gen_id }}');

              if (amountElement) {
                const formattedAmount = new Intl.NumberFormat('{{ localization.language.iso_code }}', {
                  style: 'currency',
                  currency: '{{ cart.currency.iso_code }}'
                }).format(installmentAmount);

                amountElement.textContent = formattedAmount;
              }

              this.style.display = 'block';
            } else {
              this.style.display = 'none';
            }
          }
        }
      }
    }

    customElements.define('shop-pay-installments-{{ ai_gen_id }}', ShopPayInstallments{{ ai_gen_id }});
  })();
</script>

