{% doc %}
  @prompt
    Add a custom HTML block that appears directly below the Add to Cart button on the product page. The block should be configurable in the theme editor so the merchant can enter any custom HTML content (such as trust badges, shipping info, payment icons, or promotional text) to display under the Add to Cart button.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-html-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin-top: {{ block.settings.spacing_top }}px;
    margin-bottom: {{ block.settings.spacing_bottom }}px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-custom-html-{{ ai_gen_id }} * {
    color: {{ block.settings.text_color }};
  }

  .ai-custom-html-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-custom-html-{{ ai_gen_id }} a:hover {
    opacity: 0.8;
  }

  .ai-custom-html-empty-state-{{ ai_gen_id }} {
    padding: 20px;
    background-color: #f5f5f5;
    border: 2px dashed #e8e8e8;
    border-radius: 8px;
    color: #616161;
    font-size: 14px;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .ai-custom-html-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-custom-html-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.custom_html != blank %}
    {{ block.settings.custom_html }}
  {% else %}
    <div class="ai-custom-html-empty-state-{{ ai_gen_id }}">
      Add your custom HTML content in the theme editor
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Custom HTML",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "html",
      "id": "custom_html",
      "label": "Custom HTML"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Top spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Inner padding",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#616161"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#cb1836"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Custom HTML"
    }
  ]
}
{% endschema %}