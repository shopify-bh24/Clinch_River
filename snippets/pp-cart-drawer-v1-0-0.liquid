<div
	id="pp-cart-drawer"
	class="pp-cart-drawer pp-fixed pp-gap-3 pp-top-0 pp-h-full pp-bg-white pp-shadow-lg pp-transition-transform pp-duration-300 pp-ease-in-out"
  >
	<div class="pp-w-full pp-h-full pp-flex pp-flex-col">
	  <div class="pp-cart-drawer__header pp-flex pp-items-center pp-p-5 pp-border-b pp-border-gray-200">
		<svg
		  class="pp-animate-spin pp-hidden -pp-ml-1 pp-mr-3 pp-h-5 pp-w-5 pp-text-black"
		  xmlns="http://www.w3.org/2000/svg"
		  fill="none"
		  viewBox="0 0 24 24"
		>
		  <circle class="pp-opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
		  <path class="pp-opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
		</svg>
  
		<h2 class="pp-text-xl">{{ cart_drawer_title | default: 'Your cart' }}</h2>
		<button
		  class="pp-cart-drawer__close pp-ml-auto pp-bg-none pp-border-none pp-text-2xl pp-cursor-pointer"
		  aria-label="Close cart"
		>
		  &times;
		</button>
	  </div>
  
	  <div
		class="pp-cart-drawer__items pp-h-full pp-max-h-full pp-flex-1 pp-flex pp-flex-col pp-gap-6 pp-p-5 pp-overflow-y-scroll pp-no-scrollbar"
		style="overflow-y: scroll; padding-bottom: 200px;"
	  ></div>
  
	  <div class="pp-cart-drawer__footer pp-absolute pp-bottom-0 pp-left-0 pp-right-0 pp-p-5 pp-bg-white pp-border-t pp-border-gray-200">
		<div class="pp-cart-drawer__subtotal pp-flex pp-justify-between pp-mb-4 pp-font-medium">
		  <span class="pp-text-lg">{{ cart_drawer_total_text | default: 'Total' }}</span>
		  <span class="pp-text-lg pp-cart-subtotal">$0.00</span>
		</div>
		<button class="pp-button--primary !pp-max-w-full pp-checkout-button pp-w-full pp-p-4 pp-bg-black pp-text-white pp-border-none pp-rounded pp-cursor-pointer pp-font-medium">
		  {{ checkout_button_text | default: 'Checkout' }}
		</button>
	  </div>
	</div>
  </div>
  
  <div
	id="pp-cart-drawer-overlay"
	class="pp-cart-drawer__overlay pp-hidden pp-fixed pp-top-0 pp-left-0 pp-right-0 pp-bottom-0 pp-bg-black/50"
  ></div>
  
  <style>
	.pp-cart-drawer {
		width: 500px;
		right: -500px;
		z-index: 10000;
	}
  
	.pp-cart-drawer.active {
		transform: translateX(-500px);
	}
  
	.pp-cart-drawer__overlay {
		z-index: 9999;
	}
  
	.pp-cart-drawer__overlay.active {
		display: block;
	}
  
	.pp-quantity-button:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}
  
	.pp-cart-empty {
		text-align: center;
		padding: 40px 20px;
		color: #666;
	}
  
	.pp-loading .pp-animate-spin {
		display: inline-block !important;
	}
  
	@media (max-width: 576px) {
		.pp-cart-drawer {
			width: 90%;
			right: -90%;
		}
  
		.pp-cart-drawer.active {
			transform: translateX(-100%);
		}
	}
  </style>
  
  <script>
	const productVariants = {{ product.variants | json }};
	document.addEventListener('DOMContentLoaded', () => {
	  setTimeout(() => {
		  const CartDrawer = {
			  selectors: {
				  drawer: '#pp-cart-drawer',
				  overlay: '#pp-cart-drawer-overlay',
				  items: '.pp-cart-drawer__items',
				  subtotal: '.pp-cart-subtotal',
				  closeButton: '.pp-cart-drawer__close',
				  checkoutButton: '.pp-checkout-button',
				  cartTrigger: '[data-cart-trigger]',
				  cartFooter: '.pp-cart-drawer__footer',
			  },
	  
			  drawer: null,
			  overlay: null,
			  itemsContainer: null,
			  subtotalElement: null,
			  closeButton: null,
			  checkoutButton: null,
			  cartFooter: null,
	  
			  state: {
				  isOpen: false,
				  isLoading: false,
				  cart: null,
			  },
	  
			  init() {
				  this.drawer = document.querySelector(this.selectors.drawer);
				  this.overlay = document.querySelector(this.selectors.overlay);
				  this.itemsContainer = document.querySelector(this.selectors.items);
				  this.subtotalElement = document.querySelector(this.selectors.subtotal);
				  this.closeButton = document.querySelector(this.selectors.closeButton);
				  this.checkoutButton = document.querySelector(this.selectors.checkoutButton);
				  this.cartFooter = document.querySelector(this.selectors.cartFooter);
	  
				  this.fetchCart();
	  
				  this.setupEventListeners();
			  },
	  
			  setupEventListeners() {
				  document.querySelectorAll(this.selectors.cartTrigger).forEach(trigger => {
					  trigger.addEventListener('click', e => {
						  e.preventDefault();
						  this.open();
					  });
				  });
	  
				  this.closeButton.addEventListener('click', () => this.close());
	  
				  this.overlay.addEventListener('click', () => this.close());
	  
				  this.itemsContainer.addEventListener('click', async e => {
					  const target = e.target;
	  
					  if (target.matches('.pp-quantity-button')) {
						  e.preventDefault();
						  const key = target.closest('[data-key]').dataset.key;
						  const change = target.classList.contains('pp-quantity-plus') ? 1 : -1;
						  await this.updateQuantity(key, change);
					  }
	  
					  if (target.matches('.pp-cart-item__remove')) {
						  e.preventDefault();
						  const key = target.closest('[data-key]').dataset.key;
						  await this.removeItem(key);
					  }
				  });
	  
				  this.itemsContainer.addEventListener('change', async e => {
					  if (e.target.matches('.pp-quantity-input')) {
						  const key = e.target.closest('[data-key]').dataset.key;
						  const newQuantity = parseInt(e.target.value, 10);
						  if (isNaN(newQuantity)) return;
						  await this.updateQuantity(key, newQuantity, true);
					  }
				  });
	  
				  this.checkoutButton.addEventListener('click', () => {
					  window.location.href = '/checkout';
				  });
			  },
	  
			  async fetchCart() {
				  try {
					  const response = await fetch('/cart.js');
					  if (!response.ok) throw new Error('Failed to fetch cart');
	  
					  this.state.cart = await response.json();
	  
					  this.updateCartCount();
					  this.render();
				  } catch (error) {
					  console.error('Error fetching cart:', error);
				  }
			  },
	  
			  updateCartCount() {
				  const cartCountElement = document.querySelector('.pp-cart-count');
				  const cartBubble = document.querySelector('.pp-cart-bubble');
	  
				  if (cartCountElement) {
					  cartCountElement.textContent = this.state.cart?.item_count;
				  }
	  
				  if (cartBubble) {
					  cartBubble.style.display = this.state.cart?.item_count === 0 ? 'none' : 'flex';
				  }
			  },
	  
			  async addToCart(productId, quantity = 1) {
				  try {
					  CartDrawer.setLoading(true);
	  
					  const formData = new FormData();
	  
					  if (productId) {
						  formData.append('id', productId);
					  }
	  
					  formData.append('quantity', quantity);
	  
					  const response = await fetch('/cart/add.js', {
						  method: 'POST',
						  body: formData,
					  });
	  
					  if (!response.ok) {
						  throw new Error('Failed to add item to cart');
					  }
	  
					  await CartDrawer.fetchCart();
					  this.updateCartCount();
					  CartDrawer.open();
				  } catch (error) {
					  console.error('Error adding item to cart:', error);
				  } finally {
					  CartDrawer.setLoading(false);
				  }
			  },
	  
			  async updateQuantity(key, change, absolute = false) {
				  if (this.state.isLoading) return;
	  
				  try {
					  this.setLoading(true);
	  
					  const item = this.state.cart.items.find(item => item.key === key);
					  if (!item) return;
	  
					  const quantity = absolute ? change : item.quantity + change;
					  if (quantity < 0) return;
	  
					  const response = await fetch('/cart/change.js', {
						  method: 'POST',
						  headers: {
							  'Content-Type': 'application/json',
						  },
						  body: JSON.stringify({
							  id: key,
							  quantity: quantity,
						  }),
					  });
	  
					  if (!response.ok) throw new Error('Failed to update quantity');
	  
					  this.state.cart = await response.json();
					  this.updateCartCount();
					  this.render();
				  } catch (error) {
					  console.error('Error updating quantity:', error);
				  } finally {
					  this.setLoading(false);
				  }
			  },
	  
			  async removeItem(key) {
				  await this.updateQuantity(key, 0, true);
			  },
	  
			  setLoading(isLoading) {
				  this.state.isLoading = isLoading;
			  },
	  
			  formatMoney(cents) {
				  const currency = this.state.cart?.currency || 'USD';
	  
				  return (cents / 100).toLocaleString('en-US', {
					  style: 'currency',
					  currency: currency,
				  });
			  },
	  
			  getVariantId(form) {
	  
				  // First try to get variant ID from URL
				  const urlParams = new URLSearchParams(window.location.search);
				  const urlVariantId = urlParams.get('variant');
			const firstAvailableVariant = productVariants.find(variant => variant.available);
	  
				  if (urlVariantId) {
			  let checkUrlVariant = productVariants.some(variant => variant.id === parseInt(urlVariantId));
	  
			  if( !checkUrlVariant ) {
				return firstAvailableVariant.id;
			  }
	  
			  return urlVariantId;
				  }
	  
				  // If no URL variant, fall back to form selectors
				  const id = form.querySelector('.product-variant-id')?.value || form.querySelector('.variant-id')?.value || null;
			  let checkSelectorVariant = productVariants.some(variant => variant.id === parseInt(id));
	  
			  if (!checkSelectorVariant) {
				  return firstAvailableVariant?.id || productVariants[0]?.id;
			  }
	  
				  return id;
			  },
	  
			  render() {
				  if (!this.state.cart) return;
	  
				  if (this.state.cart.item_count === 0) {
					  this.itemsContainer.innerHTML = `
			<div class="pp-cart-empty">
			  <p class="pp-text-xl">{{ cart_drawer_empty_text | default: 'Your cart is empty' }}</p>
			</div>
			`;
					  this.checkoutButton.disabled = true;
					  this.subtotalElement.textContent = this.formatMoney(0);
					  this.cartFooter.classList.add('hidden');
					  return;
				  }
	  
				  this.itemsContainer.innerHTML = this.state.cart.items
					  .map(
						  item => `
		  <div class="pp-cart-item pp-flex pp-gap-6 pp-border-b pp-border-gray-200 pp-pb-4" data-key="${item.key}">
			<div>
			  <div class="pp-flex pp-justify-center pp-items-center pp-overflow-hidden" style="width: 80px; height: 80px; border-radius: calc(var(--pp-border-radius) * 0.75);">
				<img width="85" height="85" class="pp-cart-item__image pp-rounded-lg pp-object-cover"
				  src="${item.image || ''}"
				  alt="${item.title}"
				  onerror="this.src='https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-product-1_large.png?v=1530129292'">
			  </div>
			</div>
	  
			<div class="pp-cart-item__content pp-flex pp-flex-col pp-justify-between pp-w-full">
						  <div>
			  <div class="pp-text-base pp-cart-item__title">${item.title}</div>
			  ${
						  item.variant_title
							  ? `<p class="pp-cart-item__variant pp-text-sm pp-opacity-50">${item.variant_title}</p>`
							  : ''
					  }
						  </div>
	  
						  <div class="pp-flex pp-justify-between pp-gap-2">
				  <div class="pp-flex pp-items-center pp-gap-4">
					  <div class="pp-flex pp-items-center pp-h-6 pp-border pp-border-gray-300 pp-rounded-lg">
						<button class="pp-h-full pp-px-2 pp-text-sm hover:pp-cursor-pointer pp-quantity-button pp-quantity-minus pp-touch-manipulation" ${
											  item.quantity <= 1 ? 'disabled' : ''
										  }>
										<svg fill="#000" style="width: 20px; height: 20px; pointer-events: none;" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 10c0-.414.336-.75.75-.75h8.5c.414 0 .75.336.75.75s-.336.75-.75.75h-8.5c-.414 0-.75-.336-.75-.75Z"></path></svg>
									  </button>
	  
						<input type="text" class="!pp-flex !pp-h-full !pp-w-full !pp-max-w-12 !pp-appearance-none !pp-items-center !pp-justify-center !pp-px-3 !pp-text-center !pp-text-sm !pp-border-y-0 !focus:pp-outline-none !pp-mb-0 !disabled:pp-opacity-75 !disabled:pp-bg-none pp-quantity-input" value="${
											  item.quantity
										  }" min="0" aria-label="Quantity">
	  
						<button class="pp-h-full pp-px-2 pp-text-sm hover:pp-cursor-pointer pp-quantity-button pp-quantity-plus pp-touch-manipulation">
										<svg fill="#000" style="width: 20px; height: 20px; pointer-events: none;" viewBox="0 0 20 20"><path d="M10.75 5.75c0-.414-.336-.75-.75-.75s-.75.336-.75.75v3.5h-3.5c-.414 0-.75.336-.75.75s.336.75.75.75h3.5v3.5c0 .414.336.75.75.75s.75-.336.75-.75v-3.5h3.5c.414 0 .75-.336.75-.75s-.336-.75-.75-.75h-3.5v-3.5Z"></path></svg>
									  </button>
					  </div>
					<button class="pp-cart-item__remove">
					  <svg viewBox="0 0 20 20" style="width: 20px; height: 20px; pointer-events: none;"><path d="M11.5 8.25a.75.75 0 0 1 .75.75v4.25a.75.75 0 0 1-1.5 0v-4.25a.75.75 0 0 1 .75-.75Z"></path><path d="M9.25 9a.75.75 0 0 0-1.5 0v4.25a.75.75 0 0 0 1.5 0v-4.25Z"></path><path fill-rule="evenodd" d="M7.25 5.25a2.75 2.75 0 0 1 5.5 0h3a.75.75 0 0 1 0 1.5h-.75v5.45c0 1.68 0 2.52-.327 3.162a3 3 0 0 1-1.311 1.311c-.642.327-1.482.327-3.162.327h-.4c-1.68 0-2.52 0-3.162-.327a3 3 0 0 1-1.311-1.311c-.327-.642-.327-1.482-.327-3.162v-5.45h-.75a.75.75 0 0 1 0-1.5h3Zm1.5 0a1.25 1.25 0 1 1 2.5 0h-2.5Zm-2.25 1.5h7v5.45c0 .865-.001 1.423-.036 1.848-.033.408-.09.559-.128.633a1.5 1.5 0 0 1-.655.655c-.074.038-.225.095-.633.128-.425.035-.983.036-1.848.036h-.4c-.865 0-1.423-.001-1.848-.036-.408-.033-.559-.09-.633-.128a1.5 1.5 0 0 1-.656-.655c-.037-.074-.094-.225-.127-.633-.035-.425-.036-.983-.036-1.848v-5.45Z"></path></svg>
					</button>
				  </div>
							  <p class="pp-cart-item__price">${this.formatMoney(item.final_line_price)}</p>
						  </div>
			</div>
		  </div>
		`,
					  )
					  .join('');
	  
				  this.subtotalElement.textContent = this.formatMoney(this.state.cart.total_price);
				  this.checkoutButton.disabled = false;
				  this.cartFooter.classList.remove('hidden');
			  },
	  
			  open() {
				  if (this.state.isOpen) return;
	  
				  this.state.isOpen = true;
				  this.drawer.classList.add('active');
				  this.overlay.classList.add('active');
				  document.body.style.overflow = 'hidden';
	  
				  this.fetchCart();
			  },
	  
			  close() {
				  if (!this.state.isOpen) return;
	  
				  this.state.isOpen = false;
				  this.drawer.classList.remove('active');
				  this.overlay.classList.remove('active');
				  document.body.style.overflow = '';
			  },
		  };
		  CartDrawer.init();
		  CartDrawer.fetchCart();
  
		  console.log('DOMContentLoaded');
  
		  const cart = document.querySelector('header a[href="/cart"], cart-drawer');
		  if(cart) {
			const newLink = document.createElement('a');
			  newLink.href = '/cart';
			  newLink.className = `!pp-no-underline pp-relative`;
			  if(cart.className)
				newLink.classList.add(...cart.className.split(" "));
		  
			  const wrapper = document.createElement('div');
			  wrapper.className = 'pp-relative';
			  wrapper.innerHTML =
				  '<svg width="24px" height="24px" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"></path></svg>';
	  
			  const bubble = document.createElement('div');
			  bubble.className =
				  'pp-cart-bubble pp-size-4 pp-rounded-full pp-flex pp-items-center pp-justify-center pp-text-center pp-absolute pp-bottom-0 pp-right-0';
			  bubble.style.display = 'flex';
			  bubble.style.top = '14px';
			  bubble.style.right = '-2px';
			  bubble.style.backgroundColor = 'var(--pp-button-background-color)';
			  bubble.innerHTML =
				  '<span class="pp-cart-count pp-text-xs pp-font-normal pp-tracking-tighter pp-text-white">1</span>';
	  
			  wrapper.appendChild(bubble);
			  newLink.appendChild(wrapper);
			  cart.parentNode.insertBefore(newLink, cart.nextSibling);
			  cart.remove();
			}
	
		  // Add new cart link interceptor
		  document.addEventListener('click', e => {
			  const cartLink = e.target.closest('a[href="/cart"]');
			  if (cartLink) {
				  e.preventDefault();
				  CartDrawer.open();
			  }
		  });
  
		  const headerCartButton = document.querySelector('.header__icon--cart');
		  if (headerCartButton) {
			  headerCartButton.addEventListener('click', e => {
				  e.preventDefault();
				  CartDrawer.open();
			  });
		  }
  
		  const addToCartButton = document.querySelector('.pp-button--atc');
  
		  if (addToCartButton) {
			  addToCartButton.addEventListener('click', event => {
				  event.preventDefault();
  
				  const form = event.target.closest('form');
				  const id = CartDrawer.getVariantId(form);
				  const originalText = addToCartButton.textContent;
  
				  let spinner = addToCartButton.querySelector('.pp-spinner');
  
				  if (!spinner) {
					  spinner = document.createElement('span');
					  spinner.classList.add('pp-spinner');
					  spinner.style.display = 'inline-block';
					  spinner.style.marginLeft = '8px';
					  spinner.innerHTML =
						  '<svg width="20" height="20" fill="#ffffff" class="pp-animate-spin" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M7.229 1.173a9.25 9.25 0 1011.655 11.412 1.25 1.25 0 10-2.4-.698 6.75 6.75 0 11-8.506-8.329 1.25 1.25 0 10-.75-2.385z"></path></svg>';
					  addToCartButton.appendChild(spinner);
				  }
  
				  // Clear button content and add spinner
				  addToCartButton.textContent = '';
				  addToCartButton.appendChild(spinner);
				  addToCartButton.style.opacity = '0.8';
  
				  const quantity = document.querySelector('input[name="quantity"]')?.value;
				  CartDrawer.addToCart(id, quantity ?? 1);
  
				  setTimeout(() => {
					  if (spinner) {
						  spinner.remove();
					  }
					  addToCartButton.textContent = originalText;
					  addToCartButton.style.opacity = '1';
				  }, 2000);
			  });
		  }
		  
	  }, 50);
	});
  </script>
  